{
  "xdg_config/zsh/.zshrc": {
    "type": "zshrc"
  },
  "xdg_config/zsh/completion.zsh": {
    "type": "zshcompletion"
  },
  "xdg_config/zsh/zsh-conf/custom.zsh": {
    "type": "zshcustom"
  },
  "xdg_config/pi/agent/*.json": {
    "type": "Pi"
  },
  "xdg_config/pi/agent/extensions/*/index.ts": {
    "type": "PiExt",
    "template": "// https://pi.dev/docs/latest/extensions#available-imports\nimport \"@earendil-works/pi-ai\";\nimport \"@earendil-works/pi-tui\";\nimport \"@earendil-works/pi-coding-agent\";\nimport \"typebox\";"
  },
  "xdg_config/zsh/starship/starship.toml": {
    "type": "startship"
  },
  "xdg_config/wsl/.wslconfig": {
    "type": "wsl"
  },
  "xdg_config/ghostty/config": {
    "type": "ghostty"
  },
  "xdg_config/kitty/kitty.conf": {
    "type": "kitty"
  },
  "xdg_config/wezterm/wezterm.lua": {
    "type": "wezterm"
  },
  "xdg_config/tmux/tmux.conf": {
    "type": "tmux"
  }
}
