{
  "coc.preferences.extensionUpdateCheck": "weekly",
  "coc.preferences.jumpCommand": "drop",
  "diagnostic.errorSign": "✘",
  "diagnostic.warningSign": "∆",
  "diagnostic.hintSign": "➤",
  "diagnostic.infoSign": "ℹ",
  "diagnostic.checkCurrentLine": true,
  "suggest.noselect": false,
  "list.insertMappings": {
    "<C-g>": "do:exit"
  },
  "list.normalMappings": {
    "<C-g>": "do:exit"
  },
  "go.goplsPath": "gopls",
  "go.goplsArgs": ["-remote", "auto"],
  "go.goplsOptions": {
    "completeUnimported": true
  },
  "languageserver": {
  //   "golang": {
  //     "command": "gopls",
  //     "args": [
  //       "-remote",
  //       "auto"
  //     ],
  //     "rootPatterns": [
  //       "go.mod"
  //     ],
  //     "filetypes": [
  //       "go"
  //     ],
  //     "initializationOptions": {
  //       "completeUnimported": true
  //     }
  //   },
    "bash": {
      "command": "bash-language-server",
      "args": [
        "start"
      ],
      "filetypes": [
        "sh"
      ],
      "ignoredRootPaths": [
        "~"
      ]
    }
  },
  "snippets.userSnippetsDirectory": "~/.vim/snippets",
  "snippets.ultisnips.directories": [
    "UltiSnips",
    "gosnippets/UltiSnips"
  ],
  "explorer.width": 25,
  "explorer.quitOnOpen": true,
  "explorer.openAction.strategy": "vsplit.intelligent",
  "explorer.file.showHiddenFiles": true
}
