  "list.insertMappings": {
    "<C-g>": "do:exit"
  },
  "list.normalMappings": {
    "<C-g>": "do:exit"
  },
  "go.goplsPath": "gopls",
  "go.goplsArgs": [
    "-remote",
    "auto"
  ],
  "go.goplsOptions": {
    "completeUnimported": true,
    "usePlaceholders": true
  },
  "languageserver": {
    //   "golang": {
    //     "command": "gopls",
    //     "args": [
    //       "-remote",
    //       "auto"
    //     ],
    //     "rootPatterns": [
