#! /bin/bash

# ======= helper
: "${OS:=$(uname -s | tr '[:upper:]' '[:lower:]')}"
: "${ARCH:=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')}"
have_cmd() {
	command -v "$1" >/dev/null 2>&1
}
gh_latest_tag() {
	gh release list --json tagName,isLatest --jq '.[] | select(.isLatest) | .tagName' -R "$1"
}

gh_download_release() {
	local repo=$1
	local pattern=$2
	local dir=$3
	gh release download -R "$repo" --pattern "$pattern" --dir "$dir" --clobber
}

extract_archive() {
	local archive=$1
	local dir=${2:-.}

	case "$archive" in
	*.tar.gz | *.tgz)
		tar -xzf "$archive" -C "$dir"
		;;
	*.tar.xz)
		tar -xJf "$archive" -C "$dir"
		;;
	*.zip)
		unzip -q "$archive" -d "$dir"
		;;
	*)
		echo "unsupported archive: $archive" >&2
		return 1
		;;
	esac
}
# ======= helper

install_kubectl() {
	local version=$(gh_latest_tag kubernetes/kubernetes)
	curl -o ~/.local/bin/kubectl -L "https://dl.k8s.io/release/$version/bin/${OS}/${ARCH}/kubectl"
	chmod +x ~/.local/bin/kubectl
}

install_helm() {
	local version=$(gh_latest_tag helm/helm)
	local PKG=helm-${version}-${OS}-${ARCH}.tar.gz
	local DIR=${OS}-${ARCH}
	curl -O -L "https://get.helm.sh/$PKG"
	extract_archive "$PKG"
	mv "$DIR/helm" ~/.local/bin/helm
	rm -r "$DIR"
}

install_terraform() {
	local version=$(gh_latest_tag hashicorp/terraform)
	version=${version#v}
	local PKG=terraform_${version}_${OS}_${ARCH}.zip
	curl -O -L "https://releases.hashicorp.com/terraform/$version/$PKG"
	extract_archive "$PKG"
	mv terraform ~/.local/bin/terraform
}

install_jq() {
	local jq_os
	jq_os=$(printf '%s' "$OS" | sed 's/^darwin$/macos/')

	local tmpdir
	tmpdir=$(mktemp -d)
	gh_download_release \
		jqlang/jq \
		"jq-${jq_os}-${ARCH}" \
		"$tmpdir"
	mv "$tmpdir"/jq-${jq_os}-${ARCH} ~/.local/bin/jq
	chmod +x ~/.local/bin/jq
	rm -rf "$tmpdir"
}

install_shellcheck() {
	local shellcheck_arch
	shellcheck_arch=$(printf '%s' "$ARCH" | sed 's/^amd64$/x86_64/; s/^arm64$/aarch64/')

	local tmpdir
	tmpdir=$(mktemp -d)
	gh_download_release \
		koalaman/shellcheck \
		"shellcheck-v*.${OS}.${shellcheck_arch}.tar.xz" \
		"$tmpdir"
	tar -xJf "$tmpdir"/shellcheck-v*.${OS}.${shellcheck_arch}.tar.xz -C "$tmpdir"
	mv "$tmpdir"/shellcheck-v*/shellcheck ~/.local/bin/shellcheck
	chmod +x ~/.local/bin/shellcheck
	rm -rf "$tmpdir"
}

