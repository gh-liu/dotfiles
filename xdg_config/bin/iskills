#!/usr/bin/env bash
# https://skills.sh
# skills add
# skills update

SCOPE="-g"
for arg in "$@"; do
  case "$arg" in
    --local) SCOPE="" ;;
    --clean) skills remove --all -g -y ;;
  esac
done

FLAGS="-a amp codex claude-code -y $SCOPE"

# local skills
skills add $LIU_TOOLS/dotfiles/skills $FLAGS

# find-skills:
skills add https://github.com/vercel-labs/skills --skill find-skills $FLAGS

# find-docs:
skills add https://github.com/upstash/context7 --skill find-docs $FLAGS

# brainstorming:
skills add https://github.com/obra/superpowers --skill brainstorming $FLAGS

# test-driven-development:
# skills add https://github.com/obra/superpowers --skill test-driven-development $FLAGS
# tdd
skills add mattpocock/skills/tdd $FLAGS

# fullstack-dev
skills add https://github.com/MiniMax-AI/skills --skill fullstack-dev $FLAGS

# use-modern-go:
skills add https://github.com/jetbrains/go-modern-guidelines --skill use-modern-go $FLAGS

skills add ast-grep/agent-skill
skills add vercel-labs/agent-browser

skills add https://github.com/ccheney/robust-skills --skill clean-ddd-hexagonal $FLAGS


# vim: set filetype=sh
