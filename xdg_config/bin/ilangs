#! /bin/bash

# ======= helper
: "${OS:=$(uname -s | tr '[:upper:]' '[:lower:]')}"
: "${ARCH:=$(uname -m)}"
have_cmd() { command -v "$1" >/dev/null 2>&1; }
norm_arch() {
	printf '%s' "$ARCH" | sed 's/^x86_64$/amd64/; s/^aarch64$/arm64/'
}
backup_existing() {
	local target="$1" backup="${2:-$1.bak}"
	[[ -e "$target" ]] || return 0
	rm -rf "$backup"
	mv "$target" "$backup"
}
envdir() { local d="${LIU_ENV:-$HOME/env}/$1"; mkdir -p "$d"; echo "$d"; }
cdenv() { cd "$(envdir "$1")" && pwd; }
link_bin() { mkdir -p "$HOME/.local/bin" && ln -svf "$1" "$HOME/.local/bin/$2"; }
download() {
	local url="$1" out="${2:-}"
	if [[ -n "$out" ]]; then
		mkdir -p "$(dirname "$out")" || return 1
		curl -fL --retry 3 --connect-timeout 10 -o "$out" "$url"
	else
		curl -fL --retry 3 --connect-timeout 10 -O "$url"
	fi
}
extract_archive() {
	local archive=$1
	local dir=${2:-.}
	case "$archive" in
		*.tar.gz | *.tgz) tar xzf "$archive" -C "$dir" ;;
		*.tar.xz) tar xJf "$archive" -C "$dir" ;;
		*.zip) unzip -q "$archive" -d "$dir" ;;
		*) echo "unsupported archive: $archive" >&2; return 1 ;;
	esac
}
gh_latest_tag() {
	gh release list --json tagName,isLatest --jq '.[] | select(.isLatest) | .tagName' -R "$1"
}
gh_download() {
	gh release download "$2" -R "$1" -p "$3"
}
skip_if_current() {
	local cmd="$1" version_cmd="$2" target="$3" current
	have_cmd "$cmd" || return 1
	current="$(eval "$version_cmd")"
	[[ "$current" == "$target" ]] && echo "$cmd already at $target, skipping" && return 0
	return 1
}
# ======= helper

install_go() {
	local arch version pkg url
	arch=$(norm_arch)
	version="$(curl -s "https://go.dev/dl/?mode=json" | jq -r '.[0].version')"
	skip_if_current go "go version | awk '{print \$3}'" "$version" && return 0
	pkg="$version.${OS}-${arch}.tar.gz"
	url="https://go.dev/dl/$pkg"
	echo "updating to $version (${OS}-${arch}) from $url..."
	cdenv golang
	download "$url" "$pkg" || { echo "fail to download go" >&2; return 1; }
	backup_existing go
	extract_archive "$pkg" && rm "$pkg"
	export GOPROXY=https://goproxy.io
	go install golang.org/x/tools/gopls@latest
	go install github.com/go-delve/delve/cmd/dlv@latest
}

install_zls() {
	local zls_os zls_arch version pkg
	zls_os=$(printf '%s' "$OS" | sed 's/^darwin$/macos/')
	zls_arch=$(printf '%s' "$ARCH" | sed 's/^arm64$/aarch64/')
	version="$(gh_latest_tag zigtools/zls)"
	pkg="zls-${zls_arch}-${zls_os}.tar.xz"
	echo "updating to $version (${ARCH}-${zls_os})..."
	cdenv ziglang
	gh_download zigtools/zls "$version" "$pkg" || { echo "fail to download zls" >&2; return 1; }
	extract_archive "$pkg" && rm "$pkg"
	chmod +x zls
	link_bin "$(pwd)/zls" zls
}

install_zig() {
	local zig_os zig_arch arch_key index version url pkg
	zig_os=$(printf '%s' "$OS" | sed 's/^darwin$/macos/')
	zig_arch=$(printf '%s' "$ARCH" | sed 's/^arm64$/aarch64/')
	arch_key="${zig_arch}-${zig_os}"
	index="$(curl -s https://ziglang.org/download/index.json | jq 'to_entries | map(select(.key != "master")) | max_by(.key | split(".") | map(tonumber)) | .value')"
	version="$(jq -r '.version' <<<"$index")"
	skip_if_current zig "zig version" "$version" && return 0
	url="$(jq -r ".\"$arch_key\".tarball" <<<"$index")"
	pkg="$(basename "$url")"
	echo "updating to $version ($arch_key) from $url..."
	cdenv ziglang
	download "$url" "$pkg" || { echo "fail to download zig" >&2; return 1; }
	extract_archive "$pkg" && rm "$pkg"
	backup_existing zig
	mv "zig-${arch_key}-$version" zig

	zls_version="$(gh_latest_tag zigtools/zls)"
	if [ "$zls_version" != "$version" ]; then
		echo "zls version ($zls_version) != zig version ($version), skipping zls install"
		return
	else
		install_zls
	fi
}

install_rust() {
	local dir
	dir="$(envdir rust)"
	export RUSTUP_HOME="$dir/rustup"
	export CARGO_HOME="$dir/cargo"

	if have_cmd rustup; then
		rustup update
	else
		curl https://sh.rustup.rs -sSf | sh
	fi
	rustup component add rust-analyzer rust-src
}

install_bunjs() {
	local dir
	dir="$(envdir nodejs)"
	export BUN_INSTALL="$dir/bun"

	if have_cmd bun; then
		bun upgrade
	else
		curl -fsSL https://bun.sh/install | bash
	fi
}

install_nodejs() {
	local arch ext version pkg url
	arch=$(printf '%s' "$ARCH" | sed 's/^x86_64$/x64/; s/^aarch64$/arm64/')
	[[ "$OS" == linux ]] && ext="tar.xz" || ext="tar.gz"
	version="$(gh_latest_tag nodejs/node)"
	skip_if_current node "node --version" "$version" && return 0
	pkg="node-${version}-${OS}-${arch}.${ext}"
	url="https://nodejs.org/dist/${version}/${pkg}"
	echo "updating to $version (${OS}-${arch}) from $url..."
	cdenv nodejs
	download "$url" "$pkg" || { echo "fail to download nodejs" >&2; return 1; }
	backup_existing node
	extract_archive "$pkg" && rm "$pkg"
	mv "node-${version}-${OS}-${arch}" node
}


install_uv() {
	local dir
	dir="$(envdir python)"
	export UV_INSTALL_DIR="$dir/uv"

	if have_cmd uv; then
		uv self update
	else
		if ! (
			set -o pipefail
			curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="$UV_INSTALL_DIR" sh
		); then
			echo "skip uv install" >&2
			return 0
		fi
	fi

	if have_cmd uv; then
		uv python install 3.12
		uv tool install ruff
		uv tool install ty
	fi
}

if [[ -z "$1" ]]; then
	echo "select one language: go | uv | zig | rust | bunjs"
elif declare -f "install_$1" >/dev/null; then
	echo "======== installing $1 ========"
	install_"$1"
else
	echo "unknown language: $1" >&2
	exit 1
fi
