#! /bin/bash

# ======= helper
: "${OS:=$(uname -s | tr '[:upper:]' '[:lower:]')}"
: "${ARCH:=$(uname -m)}"
have_cmd() {
	command -v "$1" >/dev/null 2>&1
}
norm_arch() {
	printf '%s' "$ARCH" | sed 's/^x86_64$/amd64/; s/^aarch64$/arm64/'
}
gh_latest_tag() {
	gh release list --json tagName,isLatest --jq '.[] | select(.isLatest) | .tagName' -R "$1"
}

gh_download_release() {
	local repo=$1
	local pattern=$2
	local dir=$3
	gh release download -R "$repo" --pattern "$pattern" --dir "$dir" --clobber
}

extract_archive() {
	local archive=$1
	local dir=${2:-.}

	case "$archive" in
	*.tar.gz | *.tgz)
		tar -xzf "$archive" -C "$dir"
		;;
	*.tar.xz)
		tar -xJf "$archive" -C "$dir"
		;;
	*.zip)
		unzip -q "$archive" -d "$dir"
		;;
	*)
		echo "unsupported archive: $archive" >&2
		return 1
		;;
	esac
}
# ======= helper

install_kubectl() {
	# https://dl.k8s.io/
	local version
	version=$(curl -fsSL https://dl.k8s.io/release/stable.txt) || return 1
	local kubectl_arch
	kubectl_arch=$(norm_arch)
	local bin="https://dl.k8s.io/release/${version}/bin/${OS}/${kubectl_arch}/kubectl"
	# echo "$bin"
	curl -o ~/.local/bin/kubectl -L "$bin"
	chmod +x ~/.local/bin/kubectl
}

install_helm() {
	local version=$(gh_latest_tag helm/helm)
	local helm_arch
	helm_arch=$(norm_arch)
	local PKG=helm-${version}-${OS}-${helm_arch}.tar.gz
	local DIR=${OS}-${helm_arch}
	curl -O -L "https://get.helm.sh/$PKG"
	extract_archive "$PKG"
	mv "$DIR/helm" ~/.local/bin/helm
	rm -r "$DIR"
}

install_terraform() {
	local version=$(gh_latest_tag hashicorp/terraform)
	version=${version#v}
	local terraform_arch
	terraform_arch=$(norm_arch)
	local PKG=terraform_${version}_${OS}_${terraform_arch}.zip
	curl -O -L "https://releases.hashicorp.com/terraform/$version/$PKG"
	extract_archive "$PKG"
	mv terraform ~/.local/bin/terraform
}

install_jq() {
	local jq_os
	jq_os=$(printf '%s' "$OS" | sed 's/^darwin$/macos/')

	local jq_arch
	jq_arch=$(norm_arch)

	local tmpdir
	tmpdir=$(mktemp -d)
	gh_download_release \
		jqlang/jq \
		"jq-${jq_os}-${jq_arch}" \
		"$tmpdir"
	mv "$tmpdir"/jq-${jq_os}-${jq_arch} ~/.local/bin/jq
	chmod +x ~/.local/bin/jq
	rm -rf "$tmpdir"
}

install_shellcheck() {
	local tmpdir
	tmpdir=$(mktemp -d)
	gh_download_release \
		koalaman/shellcheck \
		"shellcheck-v*.${OS}.${ARCH}.tar.xz" \
		"$tmpdir"
	extract_archive "$tmpdir"/shellcheck-v*.${OS}.${ARCH}.tar.xz "$tmpdir"
	mv "$tmpdir"/shellcheck-v*/shellcheck ~/.local/bin/shellcheck
	chmod +x ~/.local/bin/shellcheck
	rm -rf "$tmpdir"
}

install_stylua() {
	local stylua_os
	stylua_os=$(printf '%s' "$OS" | sed 's/^darwin$/macos/')

	local archive=stylua-${stylua_os}-${ARCH}.zip

	local tmpdir
	tmpdir=$(mktemp -d)
	gh_download_release \
		JohnnyMorganz/StyLua \
		"$archive" \
		"$tmpdir"
	extract_archive "$tmpdir/$archive" "$tmpdir"
	mv "$tmpdir"/stylua ~/.local/bin/stylua
	chmod +x ~/.local/bin/stylua
	rm -rf "$tmpdir"
}

install_nerdctl() {
	local nerdctl_arch
	nerdctl_arch=$(norm_arch)

	local archive_pattern=nerdctl-[0-9]*-${OS}-${nerdctl_arch}.tar.gz

	local tmpdir
	tmpdir=$(mktemp -d)
	gh_download_release \
		containerd/nerdctl \
		"$archive_pattern" \
		"$tmpdir" || return 1
	extract_archive "$tmpdir"/$archive_pattern "$tmpdir" || return 1
	mv "$tmpdir"/nerdctl ~/.local/bin/nerdctl || return 1
	chmod +x ~/.local/bin/nerdctl || return 1
	rm -rf "$tmpdir"
}

install_containerd() {
	local containerd_arch
	containerd_arch=$(norm_arch)

	local archive_pattern=containerd-[0-9]*-${OS}-${containerd_arch}.tar.gz

	local tmpdir
	tmpdir=$(mktemp -d)
	gh_download_release \
		containerd/containerd \
		"$archive_pattern" \
		"$tmpdir" || return 1
	extract_archive "$tmpdir"/$archive_pattern "$tmpdir" || return 1
	mv "$tmpdir"/bin/containerd ~/.local/bin/containerd || return 1
	chmod +x ~/.local/bin/containerd || return 1
	rm -rf "$tmpdir"
}

install_etcd() {
	local etcd_arch
	etcd_arch=$(printf '%s' "$ARCH" | sed 's/^x86_64$/amd64/; s/^aarch64$/arm64/')

	local archive_pattern=etcd-*-${OS}-${etcd_arch}.tar.gz

	local tmpdir
	tmpdir=$(mktemp -d)
	gh_download_release \
		etcd-io/etcd \
		"$archive_pattern" \
		"$tmpdir" || return 1
	extract_archive "$tmpdir"/$archive_pattern "$tmpdir" || return 1

	local extracted_dir
	extracted_dir=$(find "$tmpdir" -maxdepth 1 -type d -name "etcd-*-${OS}-${etcd_arch}" | head -n 1)
	[[ -n "$extracted_dir" ]] || return 1

	mv "$extracted_dir"/etcd ~/.local/bin/etcd || return 1
	mv "$extracted_dir"/etcdctl ~/.local/bin/etcdctl || return 1
	mv "$extracted_dir"/etcdutl ~/.local/bin/etcdutl || return 1
	chmod +x ~/.local/bin/etcd ~/.local/bin/etcdctl ~/.local/bin/etcdutl || return 1
	rm -rf "$tmpdir"
}

