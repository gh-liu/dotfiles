#! /bin/bash

# ======= helper
: "${OS:=$(uname -s | tr '[:upper:]' '[:lower:]')}"
: "${ARCH:=$(uname -m)}"
have_cmd() {
	command -v "$1" >/dev/null 2>&1
}
norm_arch() {
	printf '%s' "$ARCH" | sed 's/^x86_64$/amd64/; s/^aarch64$/arm64/'
}
gh_latest_tag() {
	gh release list --json tagName,isLatest --jq '.[] | select(.isLatest) | .tagName' -R "$1"
}

gh_download_release() {
	local repo=$1
	local pattern=$2
	local dir=$3
	gh release download -R "$repo" --pattern "$pattern" --dir "$dir" --clobber
}

extract_archive() {
	local archive=$1
	local dir=${2:-.}

	case "$archive" in
	*.tar.gz | *.tgz)
		tar -xzf "$archive" -C "$dir"
		;;
	*.tar.xz)
		tar -xJf "$archive" -C "$dir"
		;;
	*.zip)
		unzip -q "$archive" -d "$dir"
		;;
	*)
		echo "unsupported archive: $archive" >&2
		return 1
		;;
	esac
}
# ======= helper

# ======= kubernetes / container
_install_kubectl() {
	# https://dl.k8s.io/
	local version
	version=$(curl -fsSL https://dl.k8s.io/release/stable.txt) || return 1
	local bin="https://dl.k8s.io/release/${version}/bin/${OS}/$(norm_arch)/kubectl"
	curl -o ~/.local/bin/kubectl -L "$bin"
	chmod +x ~/.local/bin/kubectl
}

_install_helm() {
	local version arch pkg dir tmpdir
	version=$(gh_latest_tag helm/helm) || return 1
	arch=$(norm_arch)
	pkg="helm-${version}-${OS}-${arch}.tar.gz"
	dir="${OS}-${arch}"
	tmpdir=$(mktemp -d)

	curl -fsSL -o "$tmpdir/$pkg" "https://get.helm.sh/$pkg" || return 1
	extract_archive "$tmpdir/$pkg" "$tmpdir" || return 1
	mv "$tmpdir/$dir/helm" ~/.local/bin/helm || return 1
	chmod +x ~/.local/bin/helm || return 1
	rm -rf "$tmpdir"
}

_install_nerdctl() {
	[[ "$OS" == darwin ]] && {
		echo "nerdctl: no macOS release available, skipping" >&2
		return 0
	}
	local arch tmpdir
	arch=$(norm_arch)
	tmpdir=$(mktemp -d)

	local archive_pattern=nerdctl-[0-9]*-${OS}-${arch}.tar.gz
	gh_download_release \
		containerd/nerdctl \
		"$archive_pattern" \
		"$tmpdir" || return 1
	extract_archive "$tmpdir"/$archive_pattern "$tmpdir" || return 1
	mv "$tmpdir"/nerdctl ~/.local/bin/nerdctl || return 1
	chmod +x ~/.local/bin/nerdctl || return 1
	rm -rf "$tmpdir"
}

_install_containerd() {
	[[ "$OS" == darwin ]] && {
		echo "containerd: no macOS release available, skipping" >&2
		return 0
	}
	local arch tmpdir
	arch=$(norm_arch)
	tmpdir=$(mktemp -d)

	local archive_pattern=containerd-[0-9]*-${OS}-${arch}.tar.gz
	gh_download_release \
		containerd/containerd \
		"$archive_pattern" \
		"$tmpdir" || return 1
	extract_archive "$tmpdir"/$archive_pattern "$tmpdir" || return 1
	mv "$tmpdir"/bin/containerd ~/.local/bin/containerd || return 1
	chmod +x ~/.local/bin/containerd || return 1
	rm -rf "$tmpdir"
}

_install_etcd() {
	local arch ext tmpdir
	arch=$(norm_arch)
	[[ "$OS" == darwin ]] && ext="zip" || ext="tar.gz"
	tmpdir=$(mktemp -d)

	local archive_pattern=etcd-*-${OS}-${arch}.${ext}
	gh_download_release \
		etcd-io/etcd \
		"$archive_pattern" \
		"$tmpdir" || return 1
	extract_archive "$tmpdir"/$archive_pattern "$tmpdir" || return 1

	local extracted_dir
	extracted_dir=$(find "$tmpdir" -maxdepth 1 -type d -name "etcd-*-${OS}-${arch}" | head -n 1)
	[[ -n "$extracted_dir" ]] || return 1

	mv "$extracted_dir"/etcd ~/.local/bin/etcd || return 1
	mv "$extracted_dir"/etcdctl ~/.local/bin/etcdctl || return 1
	mv "$extracted_dir"/etcdutl ~/.local/bin/etcdutl || return 1
	chmod +x ~/.local/bin/etcd ~/.local/bin/etcdctl ~/.local/bin/etcdutl || return 1
	rm -rf "$tmpdir"
}

install_k8s() {
	_install_kubectl
	_install_helm
	_install_nerdctl
	_install_containerd
	_install_etcd
}

# ======= infrastructure / IaC
_install_terraform() {
	local version arch pkg tmpdir
	version=$(gh_latest_tag hashicorp/terraform) || return 1
	version=${version#v}
	arch=$(norm_arch)
	pkg="terraform_${version}_${OS}_${arch}.zip"
	tmpdir=$(mktemp -d)

	curl -fsSL -o "$tmpdir/$pkg" \
		"https://releases.hashicorp.com/terraform/$version/$pkg" || return 1
	extract_archive "$tmpdir/$pkg" "$tmpdir" || return 1
	mv "$tmpdir/terraform" ~/.local/bin/terraform || return 1
	chmod +x ~/.local/bin/terraform || return 1
	rm -rf "$tmpdir"
}

_install_terragrunt() {
	local arch tmpdir
	arch=$(norm_arch)
	tmpdir=$(mktemp -d)

	local asset=terragrunt_${OS}_${arch}
	gh_download_release \
		gruntwork-io/terragrunt \
		"$asset" \
		"$tmpdir" || return 1
	mv "$tmpdir"/"$asset" ~/.local/bin/terragrunt || return 1
	chmod +x ~/.local/bin/terragrunt || return 1
	rm -rf "$tmpdir"
}

install_iac() {
	_install_terraform
	_install_terragrunt
}

# ======= cli utilities
_install_jq() {
	local jq_os arch tmpdir
	jq_os=$(printf '%s' "$OS" | sed 's/^darwin$/macos/')
	arch=$(norm_arch)
	tmpdir=$(mktemp -d)

	gh_download_release \
		jqlang/jq \
		"jq-${jq_os}-${arch}" \
		"$tmpdir"
	mv "$tmpdir"/jq-${jq_os}-${arch} ~/.local/bin/jq
	chmod +x ~/.local/bin/jq
	rm -rf "$tmpdir"
}

_install_shellcheck() {
	local sc_arch tmpdir
	sc_arch=$(printf '%s' "$ARCH" | sed 's/^arm64$/aarch64/')
	tmpdir=$(mktemp -d)
	gh_download_release \
		koalaman/shellcheck \
		"shellcheck-v*.${OS}.${sc_arch}.tar.xz" \
		"$tmpdir"
	extract_archive "$tmpdir"/shellcheck-v*.${OS}.${sc_arch}.tar.xz "$tmpdir"
	mv "$tmpdir"/shellcheck-v*/shellcheck ~/.local/bin/shellcheck
	chmod +x ~/.local/bin/shellcheck
	rm -rf "$tmpdir"
}

# ======= lsp
_install_emmylua_ls() {
	local emmylua_arch tmpdir
	emmylua_arch=$(printf '%s' "$ARCH" | sed 's/^aarch64$/arm64/; s/^x86_64$/x64/')
	tmpdir=$(mktemp -d)

	local archive=emmylua_ls-${OS}-${emmylua_arch}.tar.gz
	gh_download_release \
		EmmyLuaLs/emmylua-analyzer-rust \
		"$archive" \
		"$tmpdir" || return 1
	extract_archive "$tmpdir/$archive" "$tmpdir" || return 1
	mv "$tmpdir"/emmylua_ls ~/.local/bin/emmylua_ls || return 1
	chmod +x ~/.local/bin/emmylua_ls || return 1
	rm -rf "$tmpdir"
}

# ======= nvimdep
_install_stylua() {
	local stylua_os stylua_arch tmpdir
	stylua_os=$(printf '%s' "$OS" | sed 's/^darwin$/macos/')
	stylua_arch=$(printf '%s' "$ARCH" | sed 's/^arm64$/aarch64/')
	tmpdir=$(mktemp -d)

	local archive=stylua-${stylua_os}-${stylua_arch}.zip
	gh_download_release \
		JohnnyMorganz/StyLua \
		"$archive" \
		"$tmpdir"
	extract_archive "$tmpdir/$archive" "$tmpdir"
	mv "$tmpdir"/stylua ~/.local/bin/stylua
	chmod +x ~/.local/bin/stylua
	rm -rf "$tmpdir"
}

