install_lsp() {
	# Go
	if have_cmd go; then
		go install golang.org/x/tools/gopls@latest
		go install github.com/bufbuild/buf/cmd/buf@latest
		go install github.com/docker/docker-language-server/cmd/docker-language-server@latest
		go install github.com/hashicorp/terraform-ls@latest
	fi

	# Bun
	if have_cmd bun; then
		bun i -g vscode-json-languageserver
		bun i -g yaml-language-server
		bun i -g bash-language-server
		bun i -g vim-language-server

		bun i -g typescript
		bun i -g typescript-language-server
		bun i -g agent-browser

		# bun i -g @github/copilot-language-server

		# bun i -g @astrojs/language-server

		# bun i -g nushell
	fi

	# uv
	if have_cmd uv; then
		uv tool install --force ast-grep-cli
		uv tool install --force basedpyright
		uv tool install --force pyright
		uv tool install --force ruff
		uv tool install --force ty
	fi

	# Cargo
	if have_cmd cargo; then
		# rustup component add rust-analyzer
		# cargo install jinja-lsp
		cargo install --features lsp --locked taplo-cli
		# cargo install --git https://github.com/ribru17/ts_query_ls.git ts_query_ls
		cargo install vimdoc-language-server

		# cargo install ast-grep
		# cargo install nu
	fi

	# Direct binaries
	_install_emmylua_ls

	# Download from https://github.com/zigtools/zls/releases
	devlangs zls
}

install_dap() {
	# uv
	if have_cmd uv; then
		uv tool install --force debugpy
		uv tool install --force pytest
	fi

	# Go
	if have_cmd go; then
		go install github.com/go-delve/delve/cmd/dlv@latest
	fi
}

install_nvimdep() {
	# Go
	if have_cmd go; then
		go install golang.org/x/tools/cmd/goimports@latest
		go install mvdan.cc/gofumpt@latest
		go install github.com/google/yamlfmt/cmd/yamlfmt@latest
		go install mvdan.cc/sh/v3/cmd/shfmt@latest
		go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest
		go install github.com/fatih/gomodifytags@latest
		go install github.com/josharian/impl@latest
		go install github.com/fullstorydev/grpcurl/cmd/grpcurl@latest
		go install github.com/AlexanderGrooff/mermaid-ascii@latest
	fi

	# Bun
	if have_cmd bun; then
		bun i -g oxlint
		bun i -g oxfmt
	fi

	# uv
	if have_cmd uv; then
		uv tool install --force isort
		uv tool install --force black
		uv tool install --force pylint
		uv tool install --force sqlfluff
	fi

	# Cargo
	if have_cmd cargo; then
		cargo install --git https://github.com/1jehuang/mermaid-rs-renderer

		cargo install --locked tree-sitter-cli

		cargo install fd-find
		cargo install ripgrep
		cargo install just

		cargo install websocat
	fi

	# Direct binaries
	_install_stylua

	# if ! have_cmd jq; then
	# 	_install_jq
	# fi

	if ! have_cmd shellcheck; then
		_install_shellcheck
	fi
}

# ======= entrypoint
if [[ -z "$1" ]]; then
	install_bins
elif declare -f "install_$1" >/dev/null; then
	install_"$1"
else
	echo "unknown component: $1" >&2
	exit 1
fi
