function! s:goto_github()
  let s:repo = matchstr(expand("<cWORD>"), '\v[0-9A-Za-z\-\_\.]+/[0-9A-Za-z\-\_\.]+')
  if empty(s:repo)
    echo "GoToGithub: No repository found."
  else
    let s:url = 'https://github.com/' . s:repo
    call netrw#BrowseX(s:url, 0)
  end
endfun
